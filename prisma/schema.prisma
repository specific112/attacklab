generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Roles & Permissions ───

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  permissions Permission[]
  users       UserRole[]
}

model Permission {
  id        String   @id @default(cuid())
  resource  String
  action    String
  createdAt DateTime @default(now())
  roles     Role[]
  @@unique([resource, action])
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  assignedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  @@unique([userId, roleId])
}

// ─── Users & Auth ───

model User {
  id                String               @id @default(cuid())
  email             String               @unique
  emailVerified     DateTime?
  username          String               @unique
  displayName       String
  passwordHash      String
  avatarUrl         String?
  bio               String?
  isActive          Boolean              @default(true)
  isSuspended       Boolean              @default(false)
  suspensionReason  String?
  failedLoginCount  Int                  @default(0)
  lockedUntil       DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  deletedAt         DateTime?

  roles               UserRole[]
  sessions            Session[]
  verificationTokens  EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
  enrollments         Enrollment[]
  lessonProgress      LessonProgress[]
  assessmentAttempts  AssessmentAttempt[]
  labSessions         LabSession[]
  labProgress         LabProgress[]
  subscription        Subscription?
  payments            Payment[]
  certificates        Certificate[]
  notifications       Notification[]
  reports             Report[]
  authenticationEvents AuthenticationEvent[]
  auditLogs           AuditLog[]
  activityLogs        ActivityLog[]
  learningStreaks     LearningStreak[]
  videoProgress       VideoProgress[]
  chapterProgress     ChapterProgress[]
  userNotes           UserNote[]
  userBookmarks       UserBookmark[]
  watchHistory        WatchHistory[]
  userActivity        UserActivity[]
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id @default(cuid())
  token        String   @unique
  userId       String
  ipAddress    String?
  userAgent    String?
  isActive     Boolean  @default(true)
  expiresAt    DateTime
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuthenticationEvent {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  eventType String
  ipAddress String?
  userAgent String?
  success   Boolean
  details   String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@index([createdAt])
}

// ─── Security: IP Blocking & Attack Logs ───

model BlockedIp {
  id          String   @id @default(cuid())
  ip          String   @unique
  reason      String
  source      String   @default("auto") // auto | manual
  blockedBy   String?  // admin userId if manual
  violationCount Int   @default(0)
  blockedAt   DateTime @default(now())
  expiresAt   DateTime? // null = permanent block
  unblockedAt DateTime?
  unblockedBy String?
  notes       String?

  @@index([ip])
  @@index([blockedAt])
  @@index([expiresAt])
}

model AttackLog {
  id        String   @id @default(cuid())
  ip        String
  type      String   // rate_limit | blocked_ua | suspicious_path | injection | auto_blocked | manual_blocked
  path      String
  method    String
  userAgent String?
  details   String?
  blocked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([ip])
  @@index([type])
  @@index([createdAt])
  @@index([blocked])
}

// ─── Audit & Activity ───

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  actorEmail String
  action     String
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// ─── Courses ───

model Course {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  description     String
  shortDescription String?
  thumbnailUrl    String?
  difficulty      String   @default("BEGINNER")
  category        String
  instructorName  String?
  isPublished     Boolean  @default(false)
  isPremium       Boolean  @default(false)
  sortOrder       Int      @default(0)
  objectives      String[]
  prerequisites   String[]
  estimatedHours  Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  modules      Module[]
  enrollments  Enrollment[]
  assessments  Assessment[]
  labs         Lab[]
  certificates Certificate[]
  resources    CourseResource[]
  analytics    CourseAnalytics?

  @@index([category])
  @@index([isPublished])
}

model Module {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]
  assessments Assessment[]

  @@index([courseId])
}

model Lesson {
  id          String   @id @default(cuid())
  moduleId    String
  title       String
  content     String   @default("")
  contentType String   @default("TEXT")
  videoUrl    String?
  duration    Int?
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  module   Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  video           Video?
  videoProgress   VideoProgress[]
  userNotes       UserNote[]
  userBookmarks   UserBookmark[]
  watchHistory    WatchHistory[]

  @@index([moduleId])
}

// ─── Enrollment & Progress ───

model Enrollment {
  id          String   @id @default(cuid())
  userId      String
  courseId     String
  status      String   @default("ACTIVE")
  enrolledAt  DateTime @default(now())
  completedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model LessonProgress {
  id         String    @id @default(cuid())
  userId     String
  lessonId   String
  status     String    @default("NOT_STARTED")
  score      Float?
  completedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

// ─── Assessments ───

model Assessment {
  id           String   @id @default(cuid())
  courseId      String?
  moduleId     String?
  title        String
  description  String?
  type         String   @default("QUIZ")
  passScore    Float    @default(70)
  timeLimit    Int?
  maxAttempts  Int?
  isPublished  Boolean  @default(false)
  shuffleQuestions Boolean @default(false)
  showAnswersAfter  Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  course   Course?             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module   Module?             @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  questions Question[]
  attempts  AssessmentAttempt[]

  @@index([courseId])
  @@index([moduleId])
}

model Question {
  id             String        @id @default(cuid())
  assessmentId   String
  type           String        @default("MULTIPLE_CHOICE")
  question       String
  explanation    String?
  points         Int           @default(1)
  sortOrder      Int           @default(0)
  createdAt      DateTime      @default(now())

  assessment     Assessment    @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  answerOptions  AnswerOption[]
  answers        AssessmentAnswer[]

  @@index([assessmentId])
}

model AnswerOption {
  id         String   @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean  @default(false)
  sortOrder  Int      @default(0)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model AssessmentAttempt {
  id             String   @id @default(cuid())
  userId         String
  assessmentId   String
  score          Float?
  totalPoints    Int?
  earnedPoints   Int?
  status         String   @default("IN_PROGRESS")
  startedAt      DateTime @default(now())
  completedAt    DateTime?
  timeSpent      Int?

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessment Assessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  answers    AssessmentAnswer[]

  @@index([userId])
  @@index([assessmentId])
}

model AssessmentAnswer {
  id           String            @id @default(cuid())
  attemptId    String
  questionId   String
  answerOptionId String?
  textAnswer   String?
  isCorrect    Boolean?
  points       Int?
  feedback     String?

  attempt      AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question     Question          @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([attemptId])
}

// ─── Labs ───

model Lab {
  id            String   @id @default(cuid())
  courseId       String?
  title         String
  slug          String   @unique
  description   String
  difficulty    String   @default("BEGINNER")
  category      String
  instructions  String
  hints         String[]
  objectives    String[]
  imageUrl      String?
  dockerImage   String?
  timeoutMinutes Int     @default(60)
  isPublished   Boolean  @default(false)
  isPremium     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  course    Course?       @relation(fields: [courseId], references: [id], onDelete: SetNull)
  sessions  LabSession[]
  progress  LabProgress[]

  @@index([courseId])
  @@index([category])
}

model LabSession {
  id          String    @id @default(cuid())
  userId      String
  labId       String
  status      String    @default("STOPPED")
  containerId String?
  port        Int?
  startedAt   DateTime?
  stoppedAt   DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lab      Lab      @relation(fields: [labId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([labId])
}

model LabProgress {
  id          String   @id @default(cuid())
  userId      String
  labId       String
  status      String   @default("NOT_STARTED")
  score       Float?
  flagsFound  Int      @default(0)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  lab  Lab  @relation(fields: [labId], references: [id], onDelete: Cascade)

  @@unique([userId, labId])
}

// ─── Subscriptions & Payments ───

model SubscriptionPlan {
  id            String   @id @default(cuid())
  name          String   @unique
  slug          String   @unique
  description   String?
  priceMonthly  Int?
  priceYearly   Int?
  currency      String   @default("USD")
  features      String[]
  maxCourses    Int?
  maxLabs       Int?
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions Subscription[]
  payments      Payment[]
}

model Subscription {
  id              String   @id @default(cuid())
  userId          String   @unique
  planId          String
  status          String   @default("ACTIVE")
  stripeSubId     String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])
  payments Payment[]

  @@index([userId])
}

model Payment {
  id               String   @id @default(cuid())
  userId           String
  planId           String?
  subscriptionId   String?
  amount           Int
  currency         String   @default("USD")
  status           String   @default("PENDING")
  provider         String   @default("stripe")
  providerTxId     String?
  paymentMethod    String?
  description      String?
  receiptUrl       String?
  failureReason    String?
  refundedAt       DateTime?
  refundAmount     Int?
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan         SubscriptionPlan? @relation(fields: [planId], references: [id])
  subscription Subscription?    @relation(fields: [subscriptionId], references: [id])

  @@index([userId])
  @@index([providerTxId])
  @@index([status])
  @@index([createdAt])
}

// ─── Certificates ───

model Certificate {
  id         String   @id @default(cuid())
  userId     String
  courseId    String
  issuedAt   DateTime @default(now())
  certNumber String   @unique

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

// ─── Notifications ───

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String?
  type      String   @default("INFO")
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

// ─── Learning Streaks ───

model LearningStreak {
  id          String   @id @default(cuid())
  userId      String   @unique
  currentStreak Int    @default(0)
  longestStreak Int    @default(0)
  lastActiveDate DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Video Learning System ───

model Video {
  id          String   @id @default(cuid())
  lessonId    String   @unique
  title       String
  description String?
  url         String?
  thumbnailUrl String?
  duration    Int      @default(0) // seconds
  fileSize    BigInt?
  resolution  String?  // e.g. "1080p", "4K"
  status      String   @default("DRAFT") // DRAFT, PROCESSING, READY, ERROR
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lesson     Lesson            @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  chapters   VideoChapter[]
  subtitles  VideoSubtitle[]
  transcripts VideoTranscript[]
}

model VideoChapter {
  id          String   @id @default(cuid())
  videoId     String
  title       String
  description String?
  startTime   Int      // seconds
  endTime     Int      // seconds
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  video            Video              @relation(fields: [videoId], references: [id], onDelete: Cascade)
  chapterProgress  ChapterProgress[]

  @@index([videoId])
}

model VideoSubtitle {
  id          String   @id @default(cuid())
  videoId     String
  language    String   @default("en")
  label       String   @default("English")
  url         String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
}

model VideoTranscript {
  id          String   @id @default(cuid())
  videoId     String
  language    String   @default("en")
  content     String   // full transcript text
  createdAt   DateTime @default(now())

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
}

model VideoProgress {
  id              String   @id @default(cuid())
  userId          String
  lessonId        String
  currentTime     Int      @default(0) // seconds
  duration        Int      @default(0)
  watchedPercent  Float    @default(0)
  isCompleted     Boolean  @default(false)
  completedAt     DateTime?
  lastWatchedAt   DateTime @default(now())
  totalTimeSpent  Int      @default(0) // seconds
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

model ChapterProgress {
  id              String   @id @default(cuid())
  userId          String
  chapterId       String
  isCompleted     Boolean  @default(false)
  completedAt     DateTime?
  createdAt       DateTime @default(now())

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter VideoChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@index([userId])
}

model UserNote {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  timestamp   Int?     // seconds - optional timestamp link
  title       String?
  content     String
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lessonId])
  @@index([userId, lessonId])
}

model UserBookmark {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  timestamp   Int      // seconds
  label       String?
  createdAt   DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId, timestamp])
  @@index([userId])
}

model CourseResource {
  id          String   @id @default(cuid())
  courseId     String
  title       String
  description String?
  fileUrl     String
  fileType    String   @default("pdf") // pdf, zip, link
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model CourseAnalytics {
  id                    String   @id @default(cuid())
  courseId              String   @unique
  totalEnrollments      Int      @default(0)
  activeEnrollments     Int      @default(0)
  videoCompletionRate   Float    @default(0)
  averageWatchTime      Float    @default(0) // seconds
  averageQuizScore      Float    @default(0)
  averageAssessmentScore Float   @default(0)
  labCompletionRate     Float    @default(0)
  certificatesEarned    Int      @default(0)
  dailyActiveLearners   Int      @default(0)
  weeklyActiveLearners  Int      @default(0)
  monthlyActiveLearners Int      @default(0)
  lastUpdated           DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model WatchHistory {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  timestamp   Int      // seconds - position watched
  watchedAt   DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lessonId])
  @@index([userId, lessonId])
}

model UserActivity {
  id          String   @id @default(cuid())
  userId      String
  type        String   // VIDEO_WATCH, LESSON_COMPLETE, QUIZ_ATTEMPT, LAB_COMPLETE, NOTE_CREATE, BOOKMARK_CREATE
  details     Json?
  xpEarned    Int      @default(0)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// ─── Legacy models (kept for compatibility) ───

model Program {
  id          String   @id @default(cuid())
  company     String
  slug        String   @unique
  description String
  maxReward   Int
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  reports     Report[]
}

model Report {
  id        String   @id @default(cuid())
  title     String
  severity  String
  cvss      Float?
  status    String   @default("DRAFT")
  createdAt DateTime @default(now())
  authorId  String
  programId String
  author    User     @relation(fields: [authorId], references: [id])
  program   Program  @relation(fields: [programId], references: [id])
}
