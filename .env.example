# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/attacklab"

# Auth
AUTH_SECRET="generate-a-random-64-character-string-for-production"
SESSION_SECRET="generate-another-random-64-character-string"
TOKEN_EXPIRY_HOURS=24
SESSION_EXPIRY_DAYS=7
REMEMBER_ME_EXPIRY_DAYS=30

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="ATTACKLAB <noreply@attacklab.com>"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3001"
NODE_ENV="development"

# Admin (only this email gets admin access)
ADMIN_EMAIL="admin@attacklab.com"

# GitHub OAuth (create at https://github.com/settings/developers)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Stripe (for payments)
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"

# Lab Infrastructure
LAB_SESSION_TIMEOUT_MINUTES=60
LAB_MAX_CONCURRENT_SESSIONS=3

# Rate Limiting & Security
RATE_LIMIT_MAX=10                     # Max requests per IP per window
RATE_LIMIT_WINDOW_MS=60000            # Window duration in ms (1 minute)
RATE_LIMIT_BLOCK_THRESHOLD=3          # Rate limit violations before auto-block
RATE_LIMIT_BLOCK_DURATION=3600000     # Auto-block duration in ms (1 hour)
ATTACK_ALERT_WEBHOOK_URL=""           # Optional webhook URL for attack alerts (Slack, Discord, etc.)
